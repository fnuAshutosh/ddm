{
  "version": 2,
  "functions": {
    "api/proxy.js": {
      "maxDuration": 300
    },
    "api/sync-belgiumdia.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/sync-belgiumdia.js",
      "schedule": "0 14 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}